DEBUG=False
DJANGO_SECRET_KEY=change-me
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
DATABASE_URL=postgresql://user:password@host:5432/dbname
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.vercel.app

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=8
EMAIL_HOST_USER=your-brevo-smtp-login
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
DEFAULT_FROM_EMAIL=verified-sender@yourdomain.com
BREVO_API_KEY=your-brevo-api-key
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_API_TIMEOUT=10
BREVO_SENDER_NAME=Captcha Free Login

OTP_EXPIRY_SECONDS=45
OTP_FALLBACK_TO_RESPONSE=False
OTP_EMAIL_RETRY_COUNT=2
OTP_EMAIL_RETRY_DELAY_MS=600

RAZORPAY_WEBHOOK_SECRET=replace-this
RAZORPAY_KEY_ID=replace-this
RAZORPAY_KEY_SECRET=replace-this
